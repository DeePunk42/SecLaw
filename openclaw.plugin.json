{
  "id": "seclaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "llm": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "model": { "type": "string", "description": "Model identifier in 'providerName/modelId' format, resolved from openclaw.json models.providers." },
          "enabled": { "type": "boolean" },
          "maxConcurrent": { "type": "number" },
          "promptRecentCalls": { "type": "number" },
          "trustedSenderLabels": { "type": "array", "items": { "type": "string" } },
          "retry": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "maxRetries": { "type": "number" },
              "initialBackoffMs": { "type": "number" },
              "cooldownMs": { "type": "number" },
              "cooldownThreshold": { "type": "number" }
            }
          },
          "apiKey": { "type": "string", "description": "Explicit API key override for SecLaw's LLM calls. Bypasses provider auth." }
        }
      },
      "timeouts": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "auditTimeoutMs": { "type": "number" },
          "syncTimeoutPolicy": { "type": "string", "enum": ["fail_closed", "fail_open"] }
        }
      },
      "logging": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
          "auditJsonl": { "type": "boolean" }
        }
      },
      "dashboard": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "port": { "type": "number" },
          "host": { "type": "string" },
          "token": { "type": "string", "description": "Bearer token for dashboard API authentication. Falls back to OPENCLAW_GATEWAY_TOKEN env var." }
        }
      },
      "scriptAudit": {
        "type": "object",
        "additionalProperties": false,
        "description": "Script content audit: reads and audits script files before execution.",
        "properties": {
          "enabled": { "type": "boolean", "description": "Enable script content audit (default: true)." },
          "extensions": { "type": "array", "items": { "type": "string" }, "description": "File extensions eligible for audit (e.g. [\".py\", \".js\", \".sh\"])." },
          "maxFileSizeBytes": { "type": "number", "description": "Skip files larger than this (default: 100000)." },
          "hashCachePath": { "type": "string", "description": "Override path for the hash cache file." }
        }
      }
    }
  }
}
