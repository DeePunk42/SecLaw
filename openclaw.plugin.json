{
  "id": "seclaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "llm": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "model": { "type": "string", "description": "Model identifier in 'providerName/modelId' format, resolved from openclaw.json models.providers." },
          "enabled": { "type": "boolean" },
          "maxConcurrent": { "type": "number" },
          "promptRecentCalls": { "type": "number" },
          "trustedSenderLabels": { "type": "array", "items": { "type": "string" } },
          "retry": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "maxRetries": { "type": "number" },
              "initialBackoffMs": { "type": "number" },
              "cooldownMs": { "type": "number" },
              "cooldownThreshold": { "type": "number" }
            }
          }
        }
      },
      "timeouts": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "syncAuditMs": { "type": "number" },
          "asyncAuditMs": { "type": "number" },
          "syncTimeoutPolicy": { "type": "string", "enum": ["fail_closed", "fail_open"] }
        }
      },
      "logging": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
          "auditJsonl": { "type": "boolean" }
        }
      },
      "rules": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "activeRuleFile": { "type": "string" }
        }
      },
      "dashboard": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "port": { "type": "number" },
          "host": { "type": "string" }
        }
      },
      "agentProfiles": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "classification": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "safeCommands": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
